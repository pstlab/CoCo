        "/objects/{id}/data": {
            "get": {
                "tags": [
                    "Objects"
                ],
                "summary": "Get object data",
                "description": "Retrieve data values for a specific object, optionally filtered by a time range.",
                "operationId": "get_data",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID of the object to retrieve data for",
                        "required": true,
