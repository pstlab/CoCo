                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "additionalProperties": {},
                                        "propertyNames": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Object not found"
                    },
                    "500": {
                        "description": "Failed to retrieve object data"
                    }
                }
            },
