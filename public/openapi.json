    "paths": {
        "/classes": {
            "get": {
                "tags": [
                    "Classes"
                ],
                "summary": "List all classes",
                "description": "Retrieve a list of all available classes in the knowledge base.",
                "operationId": "get_classes",
                "responses": {
                    "200": {
                        "description": "List of classes",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Class"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Classes"
                ],
                "summary": "Create a class",
                "description": "Create a new class in the knowledge base.",
                "operationId": "create_class",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/Class"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Class created successfully"
                    },
                    "409": {
                        "description": "Class already exists"
                    },
                    "500": {
                        "description": "Failed to create class"
                    }
                }
            }
        },
        "/classes/{name}": {
            "get": {
                "tags": [
                    "Classes"
                ],
                "summary": "Get a class",
                "description": "Retrieve details for a specific class by its name.",
                "operationId": "get_class",
                "parameters": [
                    {
                        "name": "name",
                        "in": "path",
                        "description": "Name of the class to retrieve",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
